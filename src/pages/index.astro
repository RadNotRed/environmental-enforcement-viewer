---
import {
  BarChart3,
  Database,
  Download,
  FileSpreadsheet,
  Filter,
  Globe2,
  Leaf,
  Maximize2,
  Minimize2,
  Moon,
  Search,
  ShieldCheck,
  Table2,
} from "lucide-astro";

const pathPage = Astro.url.pathname.replace(/^\/|\/$/g, "");
const currentPage = pathPage === "cases" || pathPage === "data" ? pathPage : "atlas";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Environmental prosecution database explorer with SQLite search, circuit geography, and animated globe analytics."
    />
    <title>Environmental Enforcement Atlas</title>
    <link
      rel="icon"
      href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'%3E%3Crect width='64' height='64' rx='12' fill='%23111621'/%3E%3Cpath d='M47 14c-16 2-28 12-30 27 12 0 25-8 30-27Z' fill='%2342a5f5'/%3E%3Cpath d='M18 46c8-11 15-17 27-26' stroke='%23ffb74d' stroke-width='4' stroke-linecap='round'/%3E%3C/svg%3E"
    />
  </head>
  <body data-page={currentPage}>
    <main class="app-shell">
      <aside class="sidebar" id="dataSection" aria-label="Database controls">
        <div class="brand">
          <div class="brand-mark"><Leaf size={22} /></div>
          <div>
            <p class="eyebrow">SQLite case explorer</p>
            <h1>Environmental Enforcement Atlas</h1>
          </div>
        </div>

        <section class="panel compact workbook-panel">
          <div class="panel-title">
            <Database size={18} />
            <span>Loaded Workbook</span>
          </div>
          <dl class="meta-grid" id="metaGrid">
            <div><dt>Cases</dt><dd>...</dd></div>
            <div><dt>Years</dt><dd>...</dd></div>
            <div><dt>Sheets</dt><dd>...</dd></div>
            <div><dt>Indexed</dt><dd>FTS5</dd></div>
          </dl>
        </section>

        <section class="panel compact export-panel">
          <div class="panel-title">
            <FileSpreadsheet size={18} />
            <span>Spreadsheet Export</span>
          </div>
          <p class="panel-copy">
            Download clean CSV files directly from the SQLite database for Excel, Sheets, or archive review.
          </p>
          <div class="export-actions">
            <a class="export-button primary" href="/api/export?type=cases">
              <Download size={17} />
              <span>All cases CSV</span>
            </a>
            <a class="export-button" href="/api/export?type=districts">
              <BarChart3 size={17} />
              <span>District summary</span>
            </a>
            <a class="export-button" href="/api/export?type=categories">
              <ShieldCheck size={17} />
              <span>Category summary</span>
            </a>
            <a class="export-button" href="/api/export?type=sheets">
              <Database size={17} />
              <span>Workbook sheets</span>
            </a>
          </div>
        </section>

        <section class="panel compact category-panel">
          <div class="panel-title">
            <ShieldCheck size={18} />
            <span>Category Flags</span>
          </div>
          <div id="categoryBars" class="bars" aria-live="polite"></div>
        </section>

      </aside>

      <section class="workspace">
        <header class="topbar">
          <div class="search-wrap">
            <Search size={18} />
            <input
              id="searchInput"
              autocomplete="off"
              placeholder="Search charges, districts, countries, animals/species, notes, case IDs..."
              type="search"
            />
          </div>
          <nav class="page-tabs" aria-label="Page sections">
            <button type="button" data-jump="atlas">Atlas</button>
            <button type="button" data-jump="cases">Cases</button>
            <button type="button" data-jump="data">Data</button>
          </nav>
          <div class="mode-tabs" role="tablist" aria-label="Map mode">
            <button class="active" data-mode="both" type="button">Both</button>
            <button data-mode="districts" type="button">Districts</button>
            <button data-mode="countries" type="button">Countries</button>
          </div>
          <button id="themeToggle" class="icon-button" type="button" title="Toggle theme">
            <Moon size={18} />
          </button>
        </header>

        <div id="searchPopover" class="search-popover" hidden>
          <div class="search-popover-header">
            <div>
              <p class="eyebrow">Case search</p>
              <h2 id="searchOverlayTitle">Search cases</h2>
            </div>
            <div class="result-tools">
              <span id="searchOverlayCount">Type to search</span>
              <Table2 size={18} />
            </div>
            <button id="searchClose" class="icon-button" type="button" title="Close search">×</button>
          </div>
          <div id="searchOverlayResults" class="results search-overlay-results" aria-live="polite"></div>
        </div>

        <section class="hero-grid" id="atlasSection">
          <div class="globe-stage" aria-label="Animated globe">
            <div class="globe-header">
              <div>
                <p class="eyebrow">Geography</p>
                <h2 id="mapTitle">District and circuit density</h2>
              </div>
              <div class="globe-controls">
                <div class="metric-pill">
                  <Globe2 size={17} />
                  <span id="geoCount">...</span>
                </div>
                <button
                  id="globeFullscreen"
                  class="icon-button globe-action"
                  type="button"
                  title="Fullscreen globe"
                  aria-label="Fullscreen globe"
                  aria-pressed="false"
                >
                  <Maximize2 size={18} data-fullscreen-icon="enter" aria-hidden="true" />
                  <Minimize2 size={18} data-fullscreen-icon="exit" aria-hidden="true" />
                </button>
              </div>
            </div>
            <canvas id="globeCanvas"></canvas>
            <div id="globeTooltip" class="tooltip" hidden></div>
          </div>

          <div class="insights">
            <div class="stat-grid">
              <article>
                <span>Cases</span>
                <strong id="caseCount">...</strong>
              </article>
              <article>
                <span>Total fines</span>
                <strong id="fineTotal">...</strong>
              </article>
              <article>
                <span>Restitution</span>
                <strong id="restitutionTotal">...</strong>
              </article>
              <article>
                <span>Incarceration cases</span>
                <strong id="incarcerationCount">...</strong>
              </article>
            </div>

            <section class="panel chart-panel">
              <div class="panel-title">
                <span>Timeline</span>
                <small id="yearRange">...</small>
              </div>
              <div id="timeline" class="timeline" aria-label="Case volume by year"></div>
            </section>

            <section class="panel district-panel">
              <div class="panel-title">
                <span>Top Districts</span>
                <small>click to filter</small>
              </div>
              <div id="districtList" class="district-list"></div>
            </section>
          </div>
        </section>

        <section class="results-panel" id="casesSection">
          <div class="results-header">
            <div>
              <p class="eyebrow">Case browser</p>
              <h2 id="resultsTitle">Recent cases</h2>
            </div>
            <div class="cases-toolbar">
              <div class="filter-menu">
                <button
                  id="filterToggle"
                  class="filter-toggle"
                  type="button"
                  aria-expanded="false"
                  aria-controls="caseFilters"
                >
                  <Filter size={17} />
                  <span>Filters</span>
                </button>
                <div id="caseFilters" class="filter-dropdown" hidden>
                  <label>
                    Circuit
                    <select id="circuitFilter">
                      <option value="">All circuits</option>
                    </select>
                  </label>
                  <label>
                    Sort
                    <select id="sortFilter">
                      <option value="year">Newest cases</option>
                      <option value="fine">Largest fines</option>
                      <option value="restitution">Largest restitution</option>
                      <option value="jail_prison_months">Most prison months</option>
                      <option value="case_id">Case ID</option>
                    </select>
                  </label>
                </div>
              </div>
              <div class="result-tools">
                <span id="resultCount">...</span>
                <Table2 size={18} />
              </div>
            </div>
          </div>
          <div id="results" class="results" aria-live="polite"></div>
        </section>
      </section>
    </main>

    <script is:inline type="application/json" id="atlas-webgl-source">
      import * as THREE from "three";
      import { OrbitControls } from "three/addons/controls/OrbitControls.js";

      const circuitColors = {
        "1": "#26c6da",
        "2": "#5c6bc0",
        "3": "#42a5f5",
        "4": "#ab47bc",
        "5": "#ffca28",
        "6": "#ff7043",
        "7": "#ec407a",
        "8": "#66bb6a",
        "9": "#29b6f6",
        "10": "#7e57c2",
        "11": "#00acc1",
        "12": "#d4e157",
        Unknown: "#90a4ae",
      };

      const state = {
        summary: null,
        geo: null,
        mode: "districts",
        selectedDistrict: "",
        selectedCircuit: "",
        query: "",
      };

      const $ = (selector) => document.querySelector(selector);
      const number = new Intl.NumberFormat("en-US");
      const money = new Intl.NumberFormat("en-US", {
        style: "currency",
        currency: "USD",
        maximumFractionDigits: 0,
      });

      const canvas = $("#globeCanvas");
      const tooltip = $("#globeTooltip");
      const renderer = new THREE.WebGLRenderer({
        canvas,
        antialias: true,
        alpha: true,
        powerPreference: "high-performance",
      });
      renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

      const scene = new THREE.Scene();
      const camera = new THREE.PerspectiveCamera(42, 1, 0.1, 100);
      camera.position.set(0, 0.15, 4.3);

      const controls = new OrbitControls(camera, renderer.domElement);
      controls.enableDamping = true;
      controls.autoRotate = true;
      controls.autoRotateSpeed = 0.55;
      controls.minDistance = 2.35;
      controls.maxDistance = 7;
      controls.enablePan = false;

      const globeGroup = new THREE.Group();
      scene.add(globeGroup);

      const globe = new THREE.Mesh(
        new THREE.SphereGeometry(1.5, 96, 96),
        new THREE.MeshStandardMaterial({
          color: "#0b2534",
          roughness: 0.72,
          metalness: 0.08,
          emissive: "#031018",
          emissiveIntensity: 0.9,
        }),
      );
      globeGroup.add(globe);

      const wire = new THREE.Mesh(
        new THREE.SphereGeometry(1.505, 48, 24),
        new THREE.MeshBasicMaterial({
          color: "#1dd8a1",
          wireframe: true,
          transparent: true,
          opacity: 0.12,
        }),
      );
      globeGroup.add(wire);

      const glow = new THREE.Mesh(
        new THREE.SphereGeometry(1.57, 96, 96),
        new THREE.MeshBasicMaterial({
          color: "#5c6bc0",
          transparent: true,
          opacity: 0.06,
          side: THREE.BackSide,
        }),
      );
      globeGroup.add(glow);

      scene.add(new THREE.AmbientLight("#8ee8ff", 1.25));
      const light = new THREE.DirectionalLight("#ecfeff", 2.2);
      light.position.set(3, 2, 4);
      scene.add(light);

      const pointsGroup = new THREE.Group();
      globeGroup.add(pointsGroup);
      const raycaster = new THREE.Raycaster();
      const pointer = new THREE.Vector2(100, 100);
      let hitTargets = [];

      function latLngToVector(lat, lng, radius = 1.565) {
        const phi = (90 - lat) * (Math.PI / 180);
        const theta = (lng + 180) * (Math.PI / 180);
        return new THREE.Vector3(
          -radius * Math.sin(phi) * Math.cos(theta),
          radius * Math.cos(phi),
          radius * Math.sin(phi) * Math.sin(theta),
        );
      }

      function resizeGlobe() {
        const rect = canvas.parentElement.getBoundingClientRect();
        renderer.setSize(rect.width, rect.height, false);
        camera.aspect = rect.width / rect.height;
        camera.updateProjectionMatrix();
      }

      function rebuildPoints() {
        pointsGroup.clear();
        hitTargets = [];
        const rows = state.mode === "districts" ? state.geo.districts : state.geo.countries;
        const max = Math.max(...rows.map((row) => row.cases), 1);
        for (const row of rows) {
          const coordinate = row.coordinate ?? row;
          const radius = 0.018 + Math.sqrt(row.cases / max) * 0.07;
          const color =
            state.mode === "districts"
              ? circuitColors[row.circuit] ?? "#94a3b8"
              : row.country === "United States"
                ? "#26c6da"
                : "#ffb74d";
          const marker = new THREE.Mesh(
            new THREE.SphereGeometry(radius, 18, 18),
            new THREE.MeshBasicMaterial({ color, transparent: true, opacity: 0.92 }),
          );
          marker.position.copy(latLngToVector(coordinate.lat, coordinate.lng));
          marker.userData = row;
          marker.lookAt(0, 0, 0);
          pointsGroup.add(marker);
          hitTargets.push(marker);
        }
        $("#geoCount").textContent = `${number.format(rows.length)} mapped ${state.mode}`;
        $("#mapTitle").textContent =
          state.mode === "districts" ? "District and circuit density" : "Country involvement";
      }

      function renderLoop() {
        controls.update();
        raycaster.setFromCamera(pointer, camera);
        const hit = raycaster.intersectObjects(hitTargets, false)[0];
        if (hit) {
          const row = hit.object.userData;
          tooltip.hidden = false;
          tooltip.innerHTML =
            state.mode === "districts"
              ? `<div class="tooltip-title">${row.district_name}</div><div class="tooltip-meta">${row.state} · Circuit ${row.circuit}</div><div class="tooltip-count">${number.format(row.cases)} cases</div>`
              : `<div class="tooltip-title">${row.country}</div><div class="tooltip-meta">Linked country field</div><div class="tooltip-count">${number.format(row.cases)} mentions</div>`;
        } else {
          tooltip.hidden = true;
          tooltip.innerHTML = "";
        }
        renderer.render(scene, camera);
        requestAnimationFrame(renderLoop);
      }

      canvas.addEventListener("pointermove", (event) => {
        const rect = canvas.getBoundingClientRect();
        pointer.x = ((event.clientX - rect.left) / rect.width) * 2 - 1;
        pointer.y = -((event.clientY - rect.top) / rect.height) * 2 + 1;
        tooltip.style.left = `${event.clientX - rect.left + 14}px`;
        tooltip.style.top = `${event.clientY - rect.top + 14}px`;
      });

      canvas.addEventListener("pointerleave", () => {
        pointer.set(100, 100);
        tooltip.hidden = true;
        tooltip.innerHTML = "";
      });

      canvas.addEventListener("click", () => {
        raycaster.setFromCamera(pointer, camera);
        const hit = raycaster.intersectObjects(hitTargets, false)[0];
        if (hit && state.mode === "districts") {
          state.selectedDistrict = hit.object.userData.district_name;
          loadSearch();
        }
      });

      function renderSummary() {
        const { stats, metadata, sheets, timeSeries, categoryFlags, topDistricts, circuits } =
          state.summary;
        $("#caseCount").textContent = number.format(stats.cases);
        $("#fineTotal").textContent = money.format(stats.total_fines);
        $("#restitutionTotal").textContent = money.format(stats.total_restitution);
        $("#incarcerationCount").textContent = number.format(stats.incarceration_cases);
        $("#yearRange").textContent = `${stats.first_year ?? "?"} to ${stats.last_year ?? "?"}`;

        $("#metaGrid").innerHTML = `
          <div><dt>Cases</dt><dd>${number.format(stats.cases)}</dd></div>
          <div><dt>Years</dt><dd>${stats.first_year ?? "?"}-${stats.last_year ?? "?"}</dd></div>
          <div><dt>Sheets</dt><dd>${sheets.length}</dd></div>
          <div><dt>Imported</dt><dd>${new Date(metadata.imported_at).toLocaleDateString()}</dd></div>
        `;

        const select = $("#circuitFilter");
        select.querySelectorAll("option:not(:first-child)").forEach((option) => option.remove());
        for (const row of circuits) {
          const option = document.createElement("option");
          option.value = row.circuit;
          option.textContent = `Circuit ${row.circuit} · ${number.format(row.cases)}`;
          select.append(option);
        }

        const maxYear = Math.max(...timeSeries.map((row) => row.cases), 1);
        const timelineColors = ["#42a5f5", "#26c6da", "#ffb74d", "#ab47bc", "#ec407a", "#66bb6a", "#7e57c2", "#d4e157"];
        $("#timeline").innerHTML = timeSeries
          .map(
            (row, index) =>
              `<button type="button" style="--h:${Math.max(18, Math.round((row.cases / maxYear) * 136))}px;--bar:${timelineColors[index % timelineColors.length]}" title="${row.year}: ${number.format(row.cases)} cases"><em>${number.format(row.cases)}</em><span></span><small>${row.year}</small></button>`,
          )
          .join("");

        const maxFlag = Math.max(...categoryFlags.map((row) => row.cases), 1);
        $("#categoryBars").innerHTML = categoryFlags
          .map(
            (row) =>
              `<div class="bar-row"><span>${row.label}</span><div><i style="width:${(row.cases / maxFlag) * 100}%"></i></div><b>${number.format(row.cases)}</b></div>`,
          )
          .join("");

        $("#districtList").innerHTML = topDistricts
          .map(
            (row) =>
              `<button type="button" data-district="${row.district_name}"><span><b>${row.district_name}</b><small>${row.state} · Circuit ${row.circuit}</small></span><strong>${number.format(row.cases)}</strong></button>`,
          )
          .join("");
        $("#districtList").querySelectorAll("button").forEach((button) => {
          button.addEventListener("click", () => {
            state.selectedDistrict = button.dataset.district;
            loadSearch();
          });
        });
      }

      function caseCard(row) {
        const category =
          row.category_harmonized ||
          row.category_collapsed ||
          row.category_group ||
          row.species_category ||
          "Uncategorized";
        const penalties = [
          row.fine ? `${money.format(row.fine)} fine` : null,
          row.restitution ? `${money.format(row.restitution)} restitution` : null,
          row.jail_prison_months ? `${number.format(row.jail_prison_months)} prison months` : null,
        ]
          .filter(Boolean)
          .join(" · ");
        return `<article class="case-card">
          <div>
            <h3>${row.case_id ?? row.base_id ?? "Unnamed case"}</h3>
            <p>${row.district_name ?? "Unknown district"}${row.state ? `, ${row.state}` : ""} · ${row.year ?? "No year"} · Circuit ${row.circuit ?? "?"}</p>
          </div>
          <div class="case-tags">
            <span>${category}</span>
            ${row.country_primary ? `<span>${row.country_primary}</span>` : ""}
            ${penalties ? `<span>${penalties}</span>` : ""}
          </div>
          <p class="charges">${row.charge_snippet || row.charges || "No charge text available."}</p>
        </article>`;
      }

      async function loadSearch() {
        const params = new URLSearchParams();
        if (state.query) params.set("q", state.query);
        if (state.selectedDistrict) params.set("district", state.selectedDistrict);
        if (state.selectedCircuit) params.set("circuit", state.selectedCircuit);
        params.set("sort", $("#sortFilter").value);
        const response = await fetch(`/api/search?${params}`);
        const data = await response.json();
        $("#resultsTitle").textContent = state.query
          ? `Search results for "${state.query}"`
          : state.selectedDistrict
            ? state.selectedDistrict
            : "Recent cases";
        $("#resultCount").textContent = `${number.format(data.total)} matches`;
        $("#results").innerHTML = data.rows.length
          ? data.rows.map(caseCard).join("")
          : `<div class="empty">No matching cases found.</div>`;
      }

      async function boot() {
        const [summary, geo] = await Promise.all([
          fetch("/api/summary").then((r) => r.json()),
          fetch("/api/geo").then((r) => r.json()),
        ]);
        state.summary = summary;
        state.geo = geo;
        renderSummary();
        rebuildPoints();
        resizeGlobe();
        renderLoop();
        loadSearch();
      }

      let searchTimer;
      $("#searchInput").addEventListener("input", (event) => {
        clearTimeout(searchTimer);
        searchTimer = setTimeout(() => {
          state.query = event.target.value.trim();
          state.selectedDistrict = "";
          loadSearch();
        }, 140);
      });

      $("#circuitFilter").addEventListener("change", (event) => {
        state.selectedCircuit = event.target.value;
        state.selectedDistrict = "";
        loadSearch();
      });

      $("#sortFilter").addEventListener("change", loadSearch);

      document.querySelectorAll("[data-mode]").forEach((button) => {
        button.addEventListener("click", () => {
          document.querySelectorAll("[data-mode]").forEach((item) => item.classList.remove("active"));
          button.classList.add("active");
          state.mode = button.dataset.mode;
          rebuildPoints();
        });
      });

      $("#themeToggle").addEventListener("click", () => {
        const enabled = document.body.classList.toggle("light");
        document.documentElement.classList.toggle("light", enabled);
      });

      window.addEventListener("resize", resizeGlobe);
      boot();
    </script>
    <script is:inline>
      (() => {
        const bootFallback = () => {
          if (document.getElementById("caseCount")?.textContent !== "...") return;

          const number = new Intl.NumberFormat("en-US");
          const money = new Intl.NumberFormat("en-US", {
            style: "currency",
            currency: "USD",
            maximumFractionDigits: 0,
          });
          const $ = (selector) => document.querySelector(selector);
          const canvas = $("#globeCanvas");
          const ctx = canvas.getContext("2d", { alpha: true });
          if (!ctx) return;
          const tooltip = $("#globeTooltip");
          const app = {
            summary: null,
            geo: null,
            mode: "districts",
            query: "",
            selectedDistrict: "",
            selectedCircuit: "",
            rotation: 1.7,
            zoom: 1,
            points: [],
          };
          const colors = {
            "1": "#26c6da",
            "2": "#5c6bc0",
            "3": "#42a5f5",
            "4": "#ab47bc",
            "5": "#ffca28",
            "6": "#ff7043",
            "7": "#ec407a",
            "8": "#66bb6a",
            "9": "#29b6f6",
            "10": "#7e57c2",
            "11": "#00acc1",
            "12": "#d4e157",
            Unknown: "#90a4ae",
          };

          function escapeHtml(value) {
            return String(value ?? "")
              .replaceAll("&", "&amp;")
              .replaceAll("<", "&lt;")
              .replaceAll(">", "&gt;")
              .replaceAll('"', "&quot;");
          }

          function resize() {
            const rect = canvas.parentElement.getBoundingClientRect();
            const dpr = Math.min(window.devicePixelRatio || 1, 2);
            canvas.width = Math.max(1, Math.floor(rect.width * dpr));
            canvas.height = Math.max(1, Math.floor(rect.height * dpr));
            ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
          }

          function project(lat, lng) {
            const rect = canvas.getBoundingClientRect();
            const radius = Math.min(rect.width, rect.height) * 0.31 * app.zoom;
            const cx = rect.width * 0.5;
            const cy = rect.height * 0.54;
            const phi = (lat * Math.PI) / 180;
            const lambda = (lng * Math.PI) / 180 + app.rotation;
            const cosPhi = Math.cos(phi);
            const x3 = cosPhi * Math.sin(lambda);
            const y3 = Math.sin(phi);
            const z3 = cosPhi * Math.cos(lambda);
            return {
              x: cx + radius * x3,
              y: cy - radius * y3,
              z: z3,
              radius,
              cx,
              cy,
            };
          }

          function rebuildPoints() {
            const rows = app.mode === "districts" ? app.geo.districts : app.geo.countries;
            const max = Math.max(...rows.map((row) => row.cases), 1);
            app.points = rows.map((row) => {
              const coordinate = row.coordinate || row;
              return {
                row,
                lat: coordinate.lat,
                lng: coordinate.lng,
                size: 3 + Math.sqrt(row.cases / max) * 10,
                color:
                  app.mode === "districts"
                  ? colors[row.circuit] || "#94a3b8"
                  : row.country === "United States"
                    ? "#26c6da"
                    : "#ffb74d",
              };
            });
            $("#geoCount").textContent = `${number.format(rows.length)} mapped ${app.mode}`;
            $("#mapTitle").textContent =
              app.mode === "districts" ? "District and circuit density" : "Country involvement";
          }

          function draw() {
            const rect = canvas.getBoundingClientRect();
            ctx.clearRect(0, 0, rect.width, rect.height);
            const sample = project(0, 0);
            const gradient = ctx.createRadialGradient(
              sample.cx - sample.radius * 0.35,
              sample.cy - sample.radius * 0.45,
              sample.radius * 0.08,
              sample.cx,
              sample.cy,
              sample.radius,
            );
            gradient.addColorStop(0, "#16465c");
            gradient.addColorStop(0.52, "#0b2633");
            gradient.addColorStop(1, "#041117");
            ctx.beginPath();
            ctx.arc(sample.cx, sample.cy, sample.radius, 0, Math.PI * 2);
            ctx.fillStyle = gradient;
            ctx.fill();
            ctx.strokeStyle = "rgba(144, 202, 249, 0.16)";
            ctx.lineWidth = 1;
            for (let lat = -60; lat <= 60; lat += 30) {
              ctx.beginPath();
              for (let lng = -180; lng <= 180; lng += 4) {
                const point = project(lat, lng);
                if (point.z < -0.12) continue;
                ctx[point.lng === -180 ? "moveTo" : "lineTo"]?.(point.x, point.y);
              }
              ctx.stroke();
            }
            for (let lng = -180; lng < 180; lng += 30) {
              ctx.beginPath();
              let started = false;
              for (let lat = -88; lat <= 88; lat += 3) {
                const point = project(lat, lng);
                if (point.z < -0.12) {
                  started = false;
                  continue;
                }
                if (!started) {
                  ctx.moveTo(point.x, point.y);
                  started = true;
                } else {
                  ctx.lineTo(point.x, point.y);
                }
              }
              ctx.stroke();
            }
            for (const point of app.points) {
              const projected = project(point.lat, point.lng);
              if (projected.z < -0.05) continue;
              const alpha = 0.35 + projected.z * 0.65;
              ctx.beginPath();
              ctx.arc(projected.x, projected.y, point.size * app.zoom, 0, Math.PI * 2);
              ctx.fillStyle = point.color;
              ctx.globalAlpha = alpha;
              ctx.fill();
              ctx.globalAlpha = Math.min(0.26, alpha * 0.32);
              ctx.beginPath();
              ctx.arc(projected.x, projected.y, point.size * app.zoom * 2.2, 0, Math.PI * 2);
              ctx.fill();
              ctx.globalAlpha = 1;
            }
            app.rotation += 0.0017;
            requestAnimationFrame(draw);
          }

          function renderSummary() {
            const { stats, metadata, sheets, timeSeries, categoryFlags, topDistricts, circuits } =
              app.summary;
            $("#caseCount").textContent = number.format(stats.cases);
            $("#fineTotal").textContent = money.format(stats.total_fines);
            $("#restitutionTotal").textContent = money.format(stats.total_restitution);
            $("#incarcerationCount").textContent = number.format(stats.incarceration_cases);
            $("#yearRange").textContent = `${stats.first_year ?? "?"} to ${stats.last_year ?? "?"}`;
            $("#metaGrid").innerHTML = `
              <div><dt>Cases</dt><dd>${number.format(stats.cases)}</dd></div>
              <div><dt>Years</dt><dd>${stats.first_year ?? "?"}-${stats.last_year ?? "?"}</dd></div>
              <div><dt>Sheets</dt><dd>${sheets.length}</dd></div>
              <div><dt>Imported</dt><dd>${new Date(metadata.imported_at).toLocaleDateString()}</dd></div>
            `;
            const select = $("#circuitFilter");
            select.querySelectorAll("option:not(:first-child)").forEach((option) => option.remove());
            circuits.forEach((row) => {
              const option = document.createElement("option");
              option.value = row.circuit;
              option.textContent = `Circuit ${row.circuit} · ${number.format(row.cases)}`;
              select.append(option);
            });
            const maxYear = Math.max(...timeSeries.map((row) => row.cases), 1);
            const timelineColors = ["#42a5f5", "#26c6da", "#ffb74d", "#ab47bc", "#ec407a", "#66bb6a", "#7e57c2", "#d4e157"];
            $("#timeline").innerHTML = timeSeries
              .map(
                (row, index) =>
                  `<button type="button" style="--h:${Math.max(18, Math.round((row.cases / maxYear) * 136))}px;--bar:${timelineColors[index % timelineColors.length]}" title="${row.year}: ${number.format(row.cases)} cases"><em>${number.format(row.cases)}</em><span></span><small>${row.year}</small></button>`,
              )
              .join("");
            const maxFlag = Math.max(...categoryFlags.map((row) => row.cases), 1);
            $("#categoryBars").innerHTML = categoryFlags
              .map(
                (row) =>
                  `<div class="bar-row"><span>${escapeHtml(row.label)}</span><div><i style="width:${(row.cases / maxFlag) * 100}%"></i></div><b>${number.format(row.cases)}</b></div>`,
              )
              .join("");
            $("#districtList").innerHTML = topDistricts
              .map(
                (row) =>
                  `<button type="button" data-district="${escapeHtml(row.district_name)}"><span><b>${escapeHtml(row.district_name)}</b><small>${escapeHtml(row.state)} · Circuit ${escapeHtml(row.circuit)}</small></span><strong>${number.format(row.cases)}</strong></button>`,
              )
              .join("");
            $("#districtList").querySelectorAll("button").forEach((button) => {
              button.addEventListener("click", () => {
                app.selectedDistrict = button.dataset.district || "";
                loadSearch();
              });
            });
          }

          function caseCard(row) {
            const category =
              row.category_harmonized ||
              row.category_collapsed ||
              row.category_group ||
              row.species_category ||
              "Uncategorized";
            const penalties = [
              row.fine ? `${money.format(row.fine)} fine` : null,
              row.restitution ? `${money.format(row.restitution)} restitution` : null,
              row.jail_prison_months ? `${number.format(row.jail_prison_months)} prison months` : null,
            ]
              .filter(Boolean)
              .join(" · ");
            return `<article class="case-card">
              <div>
                <h3>${escapeHtml(row.case_id || row.base_id || "Unnamed case")}</h3>
                <p>${escapeHtml(row.district_name || "Unknown district")}${row.state ? `, ${escapeHtml(row.state)}` : ""} · ${escapeHtml(row.year || "No year")} · Circuit ${escapeHtml(row.circuit || "?")}</p>
              </div>
              <div class="case-tags">
                <span>${escapeHtml(category)}</span>
                ${row.country_primary ? `<span>${escapeHtml(row.country_primary)}</span>` : ""}
                ${penalties ? `<span>${escapeHtml(penalties)}</span>` : ""}
              </div>
              <p class="charges">${row.charge_snippet || escapeHtml(row.charges || "No charge text available.")}</p>
            </article>`;
          }

          async function loadSearch() {
            const params = new URLSearchParams();
            if (app.query) params.set("q", app.query);
            if (app.selectedDistrict) params.set("district", app.selectedDistrict);
            if (app.selectedCircuit) params.set("circuit", app.selectedCircuit);
            params.set("sort", $("#sortFilter").value);
            const data = await fetch(`/api/search?${params}`).then((response) => response.json());
            $("#resultsTitle").textContent = app.query
              ? `Search results for "${app.query}"`
              : app.selectedDistrict || "Recent cases";
            $("#resultCount").textContent = `${number.format(data.total)} matches`;
            $("#results").innerHTML = data.rows.length
              ? data.rows.map(caseCard).join("")
              : `<div class="empty">No matching cases found.</div>`;
          }

          canvas.addEventListener("pointermove", (event) => {
            const rect = canvas.getBoundingClientRect();
            let hit = null;
            for (const point of app.points) {
              const projected = project(point.lat, point.lng);
              if (projected.z < -0.05) continue;
              const dx = event.clientX - rect.left - projected.x;
              const dy = event.clientY - rect.top - projected.y;
              if (Math.hypot(dx, dy) <= point.size * app.zoom + 5) hit = point;
            }
            if (!hit) {
              tooltip.hidden = true;
              tooltip.innerHTML = "";
              return;
            }
            tooltip.hidden = false;
            tooltip.style.left = `${event.clientX - rect.left + 14}px`;
            tooltip.style.top = `${event.clientY - rect.top + 14}px`;
            const row = hit.row;
            tooltip.innerHTML =
              app.mode === "districts"
                ? `<div class="tooltip-title">${escapeHtml(row.district_name)}</div><div class="tooltip-meta">${escapeHtml(row.state)} · Circuit ${escapeHtml(row.circuit)}</div><div class="tooltip-count">${number.format(row.cases)} cases</div>`
                : `<div class="tooltip-title">${escapeHtml(row.country)}</div><div class="tooltip-meta">Linked country field</div><div class="tooltip-count">${number.format(row.cases)} mentions</div>`;
          });

          canvas.addEventListener("click", (event) => {
            if (app.mode !== "districts") return;
            const rect = canvas.getBoundingClientRect();
            for (const point of app.points) {
              const projected = project(point.lat, point.lng);
              if (projected.z < -0.05) continue;
              const dx = event.clientX - rect.left - projected.x;
              const dy = event.clientY - rect.top - projected.y;
              if (Math.hypot(dx, dy) <= point.size * app.zoom + 5) {
                app.selectedDistrict = point.row.district_name;
                loadSearch();
                return;
              }
            }
          });

          canvas.addEventListener(
            "wheel",
            (event) => {
              event.preventDefault();
              app.zoom = Math.min(1.85, Math.max(0.72, app.zoom + (event.deltaY > 0 ? -0.08 : 0.08)));
            },
            { passive: false },
          );

          let searchTimer;
          $("#searchInput").addEventListener("input", (event) => {
            clearTimeout(searchTimer);
            searchTimer = setTimeout(() => {
              app.query = event.target.value.trim();
              app.selectedDistrict = "";
              loadSearch();
            }, 140);
          });
          $("#circuitFilter").addEventListener("change", (event) => {
            app.selectedCircuit = event.target.value;
            app.selectedDistrict = "";
            loadSearch();
          });
          $("#sortFilter").addEventListener("change", loadSearch);
          $("#themeToggle").addEventListener("click", () => {
            const enabled = document.body.classList.toggle("light");
            document.documentElement.classList.toggle("light", enabled);
          });
          document.querySelectorAll("[data-mode]").forEach((button) => {
            button.addEventListener("click", () => {
              document.querySelectorAll("[data-mode]").forEach((item) => item.classList.remove("active"));
              button.classList.add("active");
              app.mode = button.dataset.mode;
              rebuildPoints();
            });
          });
          window.addEventListener("resize", () => {
            resize();
            draw();
          });

          Promise.all([
            fetch("/api/summary").then((response) => response.json()),
            fetch("/api/geo").then((response) => response.json()),
          ]).then(([summary, geo]) => {
            app.summary = summary;
            app.geo = geo;
            renderSummary();
            rebuildPoints();
            resize();
            draw();
            loadSearch();
          });
        };

        window.__atlasFallbackBoot = bootFallback;
      })();
    </script>
    <script src="../scripts/atlas.ts"></script>
  </body>
</html>

